{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
<header class="anovik-header">

  {# Top strip #}
  {% if important_links %}
  <div class="anovik-header__topbar">
    <div class="container flex justify-between items-center">
      <div class="flex items-center gap-3">
        {% if important_links %}
          <salla-menu source="footer" topnav></salla-menu>
        {% endif %}
        {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
          <salla-localization-modal show-trigger></salla-localization-modal>
        {% endif %}
        {% if store.scope %}
          <button class="anovik-scope-btn"
                  onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
            <i class="sicon-location"></i> {{ store.scope.name }}
          </button>
        {% endif %}
      </div>
      <salla-contacts is-header></salla-contacts>
    </div>
  </div>
  {% endif %}

  {# Main Nav #}
  <div id="mainnav" class="anovik-header__main">
    <div class="inner anovik-header__inner">
      <div class="container">
        <div class="flex items-center justify-between">

          {# Logo + Mobile Menu #}
          <div class="flex items-center gap-3">
            <a class="lg:hidden anovik-menu-toggle" href="#mobile-menu" aria-label="Open-menu">
              <i class="sicon-menu"></i>
            </a>
            <a class="anovik-logo" href="{{ store.url }}">
              <img fetchpriority="high" loading="eager"
                   src="{{ store.logo|cdn(175) }}"
                   alt="{{ store.name }} logo">
              {% if is_page('index') %}
                <h1 class="sr-only">{{ store.name }}</h1>
              {% else %}
                <h2 class="sr-only">{{ store.name }}</h2>
              {% endif %}
            </a>
            <custom-main-menu></custom-main-menu>
          </div>

          {# Search + Actions #}
          <div class="flex items-center gap-3">
            <div class="anovik-header-search">
              <salla-search inline oval height="36"></salla-search>
            </div>
            <salla-user-menu avatar-only show-header show-trigger></salla-user-menu>
            <salla-cart-summary class="anovik-cart-btn">
              <i slot="icon" class="sicon-shopping-bag"></i>
            </salla-cart-summary>
          </div>

        </div>
      </div>
    </div>
    <div class="anovik-header__glow-line"></div>
  </div>

</header>
